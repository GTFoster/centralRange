@article{saravia2022ecological,
  title={Ecological network assembly: how the regional metaweb influences local food webs},
  author={Saravia, Leonardo A and Marina, Tom{\'a}s I and Kristensen, Nadiah P and De Troch, Marleen and Momo, Fernando R},
  journal={Journal of Animal Ecology},
  volume={91},
  number={3},
  pages={630--642},
  year={2022},
  publisher={Wiley Online Library},
  annote="Looking for empirical evidence for the impact of non-Darwinian selection process (increased persistence of stablizing network structures) on the way local foodwebs are assembled form metawebs. Using a null of random draws from a metaweb to control for network size, compared stability-related properties of local networks (motifs, functional cartography, trophic coherence, modularity, and average size of real component of 1000 Jacobian matrices) to those null models. Overall found very little difference between local and null, and emphasize that you probably don't want to take the presence of stablizing structures as evidence for dynamical constraints."
}

@article{fahimipour2014dynamics,
  title={The dynamics of assembling food webs},
  author={Fahimipour, Ashkaan K and Hein, Andrew M},
  journal={Ecology letters},
  volume={17},
  number={5},
  pages={606--613},
  year={2014},
  publisher={Wiley Online Library},
  annote="Says the colonization rate should drive many properties as foodwebs assemble; testing empirically in series of aquatic mesocosms simulating ephemeral ponds colonized by central lake. Metabolic-focused foodweb, estimating each species metabolic demands based on body size curves, and assuming equal feeding preference across all consumed species (non-equalibrial), set up mesocosms at varying distances form lake (dif dispersal rates) and either inoculated initially or not. Found that topology was pretty consistent across colonization rates despite high-turnover (partly due to lower turnover in fast-channel core), but that lower colonization rates showed less variation trophic fluxes. "
}

@article{fricke2020accelerating,
  title={Accelerating homogenization of the global plant--frugivore meta-network},
  author={Fricke, Evan C and Svenning, Jens-Christian},
  journal={Nature},
  volume={585},
  number={7823},
  pages={74--78},
  year={2020},
  publisher={Nature Publishing Group},
  doi={https://doi.org/10.1038/s41586-020-2640-y},
  annote="Looked at global plant-frugivore metaweb through time, assembled from 410 disparate networks. Found that metawebs with introduced species had significantly higher modularity and connectivity than those excluding introduced species, even after controlling for sampling effect. We're through time generally seeing biotic homogenization in these networks, and they emphasize how these less modular networks are less resiliant to change as they allow direct and indirect perturbations to more easily propagate through the system. Also found differences in invasion probability across taxa/space, with islands being more likely to be invaded by animals while continents are more likely invaded by plants. Also found that introduced species are usually better connected than natives (being a generalist is probably good for being an invader). "
}

@article{bascompte2022resilience,
  title={The Resilience of Plant--Pollinator Networks},
  author={Bascompte, Jordi and Scheffer, Marten},
  journal={Annual Review of Entomology},
  volume={68},
  year={2022},
  publisher={Annual Reviews},
  annote="Posits that we need a new framework for understanding resilience and collapse of plant-pollinator networks that 1)Allows us to define a safe operational space they can function in, and 2) addresses the rate and shape of network collapse after we leave that space. Proponents of structural stability analysis to do this (linear stability is old-school). Emphasize interactions may actually be more vulnerable to change than species themselves. Theory on critical transitions have similarities, but we have lots of species rather than one characteristic time series; what's the right one. Reference says you can find it using latent features. Increase in both variability and autocorrelation can be predictors of critical slowing down (approaching transition). Variability is good for network stability, but counter to many managment incentives in practice.  Increase in nestedness may increase overall resilience of system, but also make the final breakdown of the system more dramatic (one big failure rather than successive small ones). Lots of really good references."
}

@article{tylianakis2017ecological,
  title={Ecological networks across environmental gradients},
  author={Tylianakis, Jason M and Morris, Rebecca J},
  journal={Annual Review of Ecology, Evolution, and Systematics},
  volume={48},
  pages={25--48},
  year={2017},
  publisher={Annual Reviews}, 
  annote="Describe three mechanisms through which environmental gradients affect ecological networks: 1)changes to species composition, 2)changes that alter the probability of interactions, and c) changes to coevolutionary processes underpinning these networks. The walk through different hypothesis and mechanisms of how different gradients act through these mechanisms: a collection of random points to follow. Probability of extinction is affected both by species traits and network position. Invader role in home range is highly correlated to invasive range; generalist invaders may have hysteretic effects on networks, making removing invaders more difficult. Species-level and individual-level generality don't necessarily have to be the same thing; think about that! Interaction turnover is high in many systems; many times we see a conservation of species-level generality despite this turnover. Ecological boundaries between networks often don't follow human boundaries or at times even habitat boundaries; in many systems, we see higher connectence at habitat edges due to edge-generalists."
}

@article{memmott2007global,
  title={Global warming and the disruption of plant--pollinator interactions},
  author={Memmott, Jane and Craze, Paul G and Waser, Nickolas M and Price, Mary V},
  journal={Ecology letters},
  volume={10},
  number={8},
  pages={710--717},
  year={2007},
  publisher={Wiley Online Library},
  annote="Focused on the idea of phenological shifts causing mismatches between plant and pollinator activity periods, and how that can lead to either gaps in pollinator food availability or curtailment of flight periods. Looked at a super well-resolved plant-pollinator network observed in Illinois forest-prairie ecotone by Charles Robertson from 1884-1916. His data centers on plants, but includes pollinator survey from which they make assumptions about min and max pollinator flight period. They then randomly pull a shifted phenology from normal distributions of changes with means of 1, 2, and 3 weeks (plus randomly changed 10\% for some reason?) and looked at the gaps that were formed. Even under most conservative conditions, lots of species had gaps and/or curtailment of flight period. Discussion brings up some interesting points not addressed, chief among them probably being the potential for link rewiring under these new overlap conditions, as well as the potential (but at the time at least untested) idea that specialists may be more likely to shift more similarly to their partners than generalists. Honestly methods are seemed pretty crude today (this is 15 years old), but cool data source and super well cited."
}

@article{tylianakis2008global,
  title={Global change and species interactions in terrestrial ecosystems},
  author={Tylianakis, Jason M and Didham, Raphael K and Bascompte, Jordi and Wardle, David A},
  journal={Ecology letters},
  volume={11},
  number={12},
  pages={1351--1363},
  year={2008},
  publisher={Wiley Online Library},
  annote="Not actually as relevant as I thought it would be given the title. Not a formal metanalysis in the traditional sense; argue that numerical analysis of so many different systems is liable to lead to false conclusions/confidence levels. Just do a count of different studies analyzing Global Environmental Change (GEC) factors and their effect on different types of biotic interactions. Find that i) plant mutualisms are generally weakened, ii) effects on soil food webs are context-dependent, iii) there are often competitive shifts changing dominance structure of plants and animals, iv) often increasing herbivory severity and has variable effect on plant natural enemy attack, and finally v) increase frequency & severity of pathogen influences on plants and animals. Didn't completely read."
}

@article{lever2014sudden,
  title={The sudden collapse of pollinator communities},
  author={Lever, J Jelle and van Nes, Egbert H and Scheffer, Marten and Bascompte, Jordi},
  journal={Ecology letters},
  volume={17},
  number={3},
  pages={350--359},
  year={2014},
  publisher={Wiley Online Library},
  annote="Super sweet paper. Assembles a large number of mutualistic networks using an algorithm that can fix connectedness and proportion of forbidden links, while changing nestedness. (As I understand, it does this by drawing a network with the given constraints and then reassigning links according to rich-get-richer property until desired nestedness is reached). Then, they randomly parameterize them with LV-style population dynamics equations, and then step down pollinator growth rate to see community dynamics. Found that increasingly nested and connected networks are more likely to show one big community breakdown rather than many small ones (due to positive net effects between pollinators sustaining shared plant species). Also found these positive feedbacks caused hysterisis, with greater connectedness and nestedness also increasing degree of hysterisis. Findings support 'stress-gradient' hypothesis, where facultative  effects become more important as environment becomes more stressful. Cool marriage of critical transition theory with mutualistic network models."
}

