@article{hoover2012warming,
  title={Warming, CO2, and nitrogen deposition interactively affect a plant-pollinator mutualism},
  author={Hoover, Shelley ER and Ladley, Jenny J and Shchepetkina, Anastasia A and Tisch, Maggie and Gieseg, Steven P and Tylianakis, Jason M},
  journal={Ecology letters},
  volume={15},
  number={3},
  pages={227--234},
  year={2012},
  publisher={Wiley Online Library},
annote={Global change happens through a number of drivers, and depending on their interactions you potentially can't predict join responses to multiples of them from independent drivers alone. Examine this idea in a pumkin-bumblebee pollination system, looking at the effects of N deposition, warming, and pCO2 together and seperately on nectar chemistry, amount, flower traits, pollinator preferences, and effect on pollinator fitness. Factorial design of either baseline or elevated of all 3, total of 9 treatments. Saw changes in flower traits (size, #, nectar chemistry), and then used the nectar chemistry info to give artificial choice and longevity experiments to worker bees from different hives. All three drivers had significant, non-additive effects on floral traits, and potential mistmatches between pollinator preference and fitness (most preferred nectar had 22% shorther survival) means potentially degredation of the ineraction.}
}

@article{warren2014mutualism,
  title={Mutualism fails when climate response differs between interacting species},
  author={Warren, Robert J and Bradford, Mark A},
  journal={Global Change Biology},
  volume={20},
  number={2},
  pages={466--474},
  year={2014},
  publisher={Wiley Online Library},
annote={Paper looking at disruption of seed dispersal mutualisms between small herbs and two and species. There's an early and late season foraging ant, with a boundary seperating their distreibution-look at dispersal of early and late blooming plants transplanted above and below the boundary. Found that the southern plant (early) lost dispersal ability when transplanted into northern range of late disperser, but when northern late bloomer was brought south they were still dispersed by the early ant. Dispersal in this case was measured by distance from mother plant & clumpiness of distributions. Small study, but go from phenological breakdown of interaction to population-level consequence. Both partners are generally shifting northward, but brings up differences in dispersal rates (ant-dispersed plants of 1-2m/year, while ant mating flights can disperse 50-100m/year), as an example of how biotic limitations (partner loss) may cause extirpations along range edges, and argue they may be more important to limiting distributions that the traditional fundamental/realized niche deliniation may say. Also, their southern site was Whitehall!}
}


