  author={Cruz, Austin R and Davidowitz, Goggy and Moore, Christopher M and Bronstein, Judith L},
  journal={Ecology Letters},
  year={2023},
  publisher={Wiley Online Library},
annote={Large synthesis, focused on proposing a trait-based mechanistic framework for modeling and predicting how mutualistic interactions may change under warming conditions. Derived from more classic thermal-ecology principles, extends thermal performance curves to mutualisms, which are unique in that they're affected by traits of each partner. TPCs are usually left-skewed unimodal curves (though sometimes symmetric or right-skewed). Interaction is controlled by TPC of production (either of service or reward) and utilization of both partners; "Mutualism Thermal Performance Curve" or MTPC is created by finding the overlapping area of these interacting traits. Scale by dividing by the smallest possible AUC, adding in range [0,1] in increase interpretiability. Also spend time discussing "Y" model of resource allocation. Lots of takeaways I didn't spend enough time with, but crux being predicting the outcome of mutualisms in a thermal-ecology framework requires you to think about how both species TPCs may be changing.}
}

@article{teixido2022anthropogenic,
  title={Anthropogenic impacts on plant-animal mutualisms: A global synthesis for pollination and seed dispersal},
  author={Teixido, Alberto L and Fuzessy, Lisieux F and Souza, Camila S and Gomes, Ingrid N and Kaminski, Lucas A and Oliveira, Patricia C and Maruyama, Pietro K},
  journal={Biological Conservation},
  volume={266},
  pages={109461},
  year={2022},
  publisher={Elsevier},
  annote={Review article, trying to get a sense of how a broad sense of anthrpogenic impacts (agrochemicals, climate change, fire, fragmentation, hunting, non-native species, and urbanization) impact both plant-pollinator interactions as well as plant-disperser interactions. Emphasized that both of these contribute to different portions of overall plant life-cycle, and ultimately plant grwoth rate and should be jointly considered as such. Large metanalysis; skipped over their querying methods and stats, but generally binned studies into +, -, and 0 effects. Describe a lot of geographic and taxonomic biases that exist in current lit. Other takeaways, but generally pollination mutualisms are most negatively affected by climate change (mediated assemblage-level factors of spatio-temporal mismatches), while dispersal mutualisms are most negatively impacted by native species. In general, pollinators more negatively affected than their partner plants.}
}

@article{thebault2010stability,
  title={Stability of ecological communities and the architecture of mutualistic and trophic networks},
  author={Th{\'e}bault, Elisa and Fontaine, Colin},
  journal={Science},
  volume={329},
  number={5993},
  pages={853--856},
  year={2010},
  publisher={American Association for the Advancement of Science},
  annote={Short, two-part Science paper; they 1) use simulations to make model predictions about how structural properties affect the stability and resiliance of both mutualistic and trophic networks (emphasizing in which ways they differ), and then 2) look for their observed structural patterns in nature. Four focused on patters were 1)diversity, 2)connectance, 3)nestedness, and 4)modularity. Used path analyses to try and seperate out direct and indirect effects. Species could go extinct;  found that extinctions in mutualistic systems tended to increase connectedness and nestedness, but decrease modularity. In contrast, extinctions in trophic communities tended to decreases connectedness, while also increasing nestedness and decreasing modularity. Diversity and connectance promoted resiliance of mutualistic systems, but tended to destabilize trophic networks. In empirical search (~35 plant-poll and ~25 herbivory) found that mutuslistic networks were less modular and more nested, and the slope between connectance and diversity, while still negative, was less strong. Say that many of the features they found in empirical networks were ones identified to be stablizing in theoretical systems.}
}

@article{schleuning2016ecological,
  title={Ecological networks are more sensitive to plant than to animal extinction under climate change},
  author={Schleuning, Matthias and Fr{\"u}nd, Jochen and Schweiger, Oliver and Welk, Erik and Albrecht, J{\"o}rg and Albrecht, Matthias and Beil, Marion and Benadi, Gita and Bl{\"u}thgen, Nico and Bruelheide, Helge and others},
  journal={Nature communications},
  volume={7},
  number={1},
  pages={13965},
  year={2016},
  publisher={Nature Publishing Group UK London},
annote={Combined the old SDM + climate prediction approach with network analyses to test potential climate-mediated impacts on 700 pollinator/seed dispersal partners in Central Europe. Found the animal spp. w/narrow climate niches and a projected loss of climate suitability interact with a low diversity of plants, making the likely sensitive to host plant-extinctions. This isn't the same for plants, leading them tp conclude that these networks are a lot more sensitive to bottom-up effects of losing plants than top-down ones. Found that animal climatic niche breadth was positively associated with generalism, while unrealted for plants. This could be a number of mechanisms, include range-abundance relationships, range-traits associated with generalism relationships (i.e. body size), or my personal favorite, that the ranges of animals are limted by the distributions of their plant partners. This latter has been observed in antagonistic plant-herbivore systems, but they say is yet unobserved in mutualistic systems. The simulate dynamics in these newtorks and look for patterns of secondary extinctions as they remove species in order of most to least affected by climate shifts. They vary extinction thresholds for the proportion of partnerships that must be lost, as well as have a few different potential rewiring regimes (ranging from quite conservitive to superal liberal). Found that secondary extinctions driven by climate were worse than the same number of random extinctions. The severness of bottom-up extinction effects was reduced when animals could redistribute the majority of interaction weight to persistant species in the network, highlighting the importance of interaction adaptablity for network persistance.}
}

@article{gerard2020global,
  title={Global warming and plant--pollinator mismatches},
  author={G{\'e}rard, Maxence and Vanderplanck, Maryse and Wood, Thomas and Michez, Denis},
  journal={Emerging topics in life sciences},
  volume={4},
  number={1},
  pages={77--86},
  year={2020},
  publisher={Portland Press Ltd.},
annote={Short and sweet review of literature evidence for global warming impacting plant-pollinator (specifically instect-plant) interactions through i) spatial mismatch, ii) temporal mismatch, iii)morphological modification, and iv) behavioral modifications. Good review of lit and has a number of good case studies; most new (but also maybe most tenuous) assertions are in sections III and IV. We have evidence that phenological mismatches are occuring and can affect plant fitness (e.g. reducing seed set), but at time of publication no real evaluation of pollinator fitness. Generalism may buffer some mistmatches, though we also see a reduction in reduncancy and complimentarity across networks, potentially leaving them more vulnerable to preterbation. Warming can cause morphological mismatches between insects (where body size is pretty consistently negatively related to temp) and plants (who show much less consistent changes)-probably not a big deal for generalists, but may matter more for specialists who require specific morphologies for effective feeding and/or pollentransfer. Also, heat stress seems to matter a lot for pollen quality, in terms of both viability and nutritional content. Behavioral changes can also cause breakdown, either as animals change foragin behaviros in response to warming, or as things like plant Volatile Organic Compound components used for signaling change/olfactory environment becomes busier with warming increasing production.}
}

@article{stebbins1970adaptive,
  title={Adaptive radiation of reproductive characteristics in angiosperms, I: pollination mechanisms},
  author={Stebbins, G Ledyard},
  journal={Annual review of ecology and systematics},
  volume={1},
  number={1},
  pages={307--326},
  year={1970},
  publisher={Annual Reviews 4139 El Camino Way, PO Box 10139, Palo Alto, CA 94303-0139, USA},
annote={Genesis of the 'most effective pollinator principle', described in 1. on bottom of 318, which states that "states that when pollinators are not limiting, plants are expected to specialize and adapt to the most abundant and effective pollinator species available." (Summary from Medel 2018, Biology Letters). This doesn't mean that plants are only visited by that pollinator, and visits from others can alter the pace of evolution towards that relationship, but are unlikely to change its overall course accoring to Stebbins.}
}

@article{suweis2013emergence,
  title={Emergence of structural and dynamical properties of ecological mutualistic networks},
  author={Suweis, Samir and Simini, Filippo and Banavar, Jayanth R and Maritan, Amos},
  journal={Nature},
  volume={500},
  number={7463},
  pages={449--452},
  year={2013},
  publisher={Nature Publishing Group UK London},
annote={Another paper saying that structural features like nestedness may not actually due to network-stability-based methods,  but instead show a mathmatical model where they can result from optimization of both individual spp and total community abundance. Have a mutualistic system of S species and include both competition and benefit from mutualism; use both type I and type II Holling functional response (unclear if one for each ,or these are diff simulations). Show that when you allow system to reach stationarity as is and then sequentially rewire (keeping other features the same), increase in nestedness is associated with increases in total species abundance. Effect is stronger in regimes with relatively weak mutualisms rather than strong ones, potentially due to weak systems more strongly benefiting from optimal tuning. This increase in total community abundance increases robustness to stochastic extinction, but decreases resiliance in the sense that the community takes longer to recover after disturbance.}
}

@article{guimaraes2020structure,
  title={The structure of ecological networks across levels of organization},
  author={Guimaraes Jr, Paulo R},
  journal={Annual Review of Ecology, Evolution, and Systematics},
  volume={51},
  pages={433--460},
  year={2020},
  publisher={Annual Reviews},
annote={Very broad overview, not as directly applicable as I had though but still including some good points. Stream of Conciousness points: A network approach is inherently simplifying, and scaling up from IBN's to species-level to clade-level networks makes you especially aware of this. Better information about individual networks may provide insight into novel mechanisms causing structural features, but may not actually be what's needed as much in the pursuit of generality (the motivation of our theory). Need to make sure we're incorporating proper null models when looking for things like network structure, but just because a simple null can recreate a natural pattern doesn't mean it's not important. It may not require more complex mechanisms to generate, but can still have big impacts on the dynamics of the system. While we know a pretty good bit about foodwebs and some types of mutualistic networks, our knowledge about IBNs as well as broad, region-scale webs is still pretty limited. Disconnected and connected graph regimes are actually along a pretty simple continum of transition from basic graph theory principles, and we may be more likely to see fully connected graphs as we move up levels of organization (another good reason to use carefully thought out  null models). NEstedness may be a consequence of skewed species abundace and/or trait distributions. Different features may emerge at different scales (ex. local butterfly-plant herbivors networks often look quite specialized and modular, but at broader phylogenetic scales can show a pretty high degree of nestedness). "Mutualistic network" vs "floral vistation network" distinction-probably still reasonable to call it the former even though not all interactions are mutualistic, as there would be no commensuals or  for shaping the course of evolution of connected species-they vastly outnumber direct interactions just by virtue of geometry, and keystone species are a good case-study for that.}
}

@article{vidal2021variable,
  title={The variable effects of global change on insect mutualisms},
  author={Vidal, Mayra C and Anneberg, Thomas J and Cur{\'e}, Anne E and Althoff, David M and Segraves, Kari A},
  journal={Current Opinion in Insect Science},
  volume={47},
  pages={46--52},
  year={2021},
  publisher={Elsevier},
annote={Short, somewhat broad review emphasizing that not all insect mutualisms are going to change in the say way in response to global change, but that there a number of key factors we should be thinking about when trying to make good predictions. We should both think about the direct effects of warming as well as indirect effects through ecological/trophic context. Things like cost-benefit rations, degree of obligation, and specialiization all matter. Rapid coevolution could be an potentially big avenue, but we need more observational studies as we have some conflicting theory. Other small notes are that some refs are available to talk about how phenological mismatches are so far somewhat rate, potentially due to coevolutionary history of phenolohical cues. Also, range shifts are affected not only by the immediate ecological response, but also patterns of parallel adaptation (or lack therof). Native mutualistic networks may be somewhat buffered by invading spp. as even if associations form, the actually subset with real fitness consequences may be preserved. There are beetle-slime mold mutualisms.}
}

