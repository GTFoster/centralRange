@article{pichler2020machine,
  title={Machine learning algorithms to infer trait-matching and predict species interactions in ecological networks},
  author={Pichler, Maximilian and Boreux, Virginie and Klein, Alexandra-Maria and Schleuning, Matthias and Hartig, Florian},
  journal={Methods in Ecology and Evolution},
  volume={11},
  number={2},
  pages={281--293},
  year={2020},
  publisher={Wiley Online Library},
  annote="Compare a variety of Machine Learning Models to GLMs in their ability both to predict links and uncover causal traits. Apply to a bunch of simulated networks, as well as two empirical networks: a large global crop-pollinator network and a small hummingbird-flower network from Costa Rica. Overall, found that even when interactions where driven by a small number of traits, Boosted Regression Tree, Random Forest, and Deep Neural Net approaches could outperform GLM's. More importantly performance of ML approaches stayed the same or got better with increasing number of causal traits, while GLMs got significantly worse. Downside they talked about is sensitivity of ML approaches to class imbalances (0's vs 1's), which in real networks is huge. Simulated 40\% proportions in simulated networks, which is super filled out. When less than 20 \% empirically, oversampled + interactions until you hit 20 \%; cited as standard approach \cite{krawczyk2016}. Also talked about how differences in abundance can lead to AUC $>$ 0.5 without traits, and abundance distributions may mask causal traits (a bit unclear for me). Overall cool paper and results, but worried about not addressing sparseness of many ecological networks."
}

