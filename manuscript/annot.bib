@article{burkle2011future,
  title={The future of plant--pollinator diversity: understanding interaction networks across time, space, and global change},
  author={Burkle, Laura A and Alarc{\'o}n, Ruben},
  journal={American journal of botany},
  volume={98},
  number={3},
  pages={528--538},
  year={2011},
  publisher={Wiley Online Library},
  annote={``Review of many types of studies (observational, theoretical (barely), and experimental) that look at spatial or temporal variation in plant-pollinator interaction networks. Both types of variability are interesting, in part due to things like land-use changes/gradients and phenological decoupling associated with climate change. When thinking about the scale we should characterize networks, the scale of analysis should be biologically motivated. Lumping together too-large times or geographic distances can overreppresent forbidden links and cause you to misrepresent network & conclusions about generalism or turnover. There's a number of examples of conserved network traits across space and time despite high levels of species turnover, possibly indicating separate mechanisms of network assembly and species composition. Interaction doesn't always meaning pollination though, and it's possible that more truly mutualistic interactions are more conserved that opportunistic ones or cheating. Because of differences in mobility, space may mean very different things for plants and pollinators."}
}

@article{toby2010mutualisms,
  title={Mutualisms in a changing world: an evolutionary perspective},
  author={Toby Kiers, E and Palmer, Todd M and Ives, Anthony R and Bruno, John F and Bronstein, Judith L},
  journal={Ecology letters},
  volume={13},
  number={12},
  pages={1459--1474},
  year={2010},
  publisher={Wiley Online Library},
  annote={``Mutualism breakdown has the potential to expand and accelerate the effects of anthropogenic change, but we still don't have the evo perspective we need in spite of this. Table 1 has good examples of different global change drivers and example effects they have on a variety of mutualist systems, as well as potential ecoevo effects and questions stemming from these. Also has good list of reviews of global change-species interactions reviews circa 2010. Focus on three potential process of mutualism breakdown and evo perspective; 1) shifts from mutualism to antagonism, 2) development of novel partnerships, and 3) interaction extinctions [empty forest syndrome]. 
  
  Stream of Consciousness Points:  Mutualism cost:benefit relationships can change depending on environmental context; differences in generation times among partners (eg. ants & ant-trees) can make them respond at very different evolutionary rates. Things that seem like functional redundant partners may actually be only functionally complementary. We see some examples of loss of obligate partnerships in novel environments; may be more likely when maintenance cost is high. We may see reinforced mutualisms with the introduction of nonnative partners, or when environmental context strengthens the benefits of an interaction. To predict evo responses, need 1) basic knowledge on the relationship between evolutionary shifts and mutualism type, 2) to map past climatic events on to mutualist phylogenies, and 3) better understand what makes 'resilient' mutualisms. Ends with 4 questions they say we should ask when studying evo effects of global change on mutualisms."}
}

@article{valdovinos2019mutualistic,
  title={Mutualistic networks: moving closer to a predictive theory},
  author={Valdovinos, Fernanda S},
  journal={Ecology letters},
  volume={22},
  number={9},
  pages={1517--1534},
  year={2019},
  publisher={Wiley Online Library},
  annote={``Really good review; will be rereading many sections for MetaComm. First section organizes existing lit on qualitative predictions made by different bodies of mutualistic network theory, in what settings those expectations have been empirically tested, and where are holes we need to fill with future empirical studies (Table 1 particularly useful review). Broadly organized into three sections, focusing on how theory predicts structure, dynamics, and response of networks to global perturbation. In structure section, brings up fact that using complimentary data sources to assemble networks can help circumvent Bluthgen's sampling effect problem, as well as the fact you can often robustly characterize higher order interactions/structure even without a fully fleshed out network. 
 In dynamics, generally argues against LV models in favor of consumer-resource approach. Notes that frequency of interaction often is correlated with abundance and can't be used to estimate per-capita effect, and that LV models ignoring mechanism can make predictions about the role of structural properties (esp. nestedness and connectance) on stability at odds with empirical work. Also provides large table 2 breakdown of LV model variations, useful to reference for MetaComm. Consumer-Resource approach separates plant reward abundance from vegetative biomass, and more easily includes plasticity in link requiring and foraging strategies. Even though accounted for differently in many modeling frameworks, plasticity in species interactions often results in a more stable network. Finally, argues that more mechanistic theoretical models are more useful for predictions, as the fact that they give shorter-term predictions testable against empirical data can give us more confidence in their long-term predictions."}
}


@article{van2021facultative,
  title={Facultative mutualisms: a double-edged sword for foundation species in the face of anthropogenic global change},
  author={van Der Heide, Tjisse and Angelini, Christine and de Fouw, Jimmy and Ekl{\"o}f, Johan S},
  journal={Ecology and Evolution},
  volume={11},
  number={1},
  pages={29--44},
  year={2021},
  publisher={Wiley Online Library},
  annote={Relatively simple paper but brings up the point that facultative mutualists can strengthen self-facilitating feedbacks created by some foundation species (i.e. tropical trees increasing moisture of microclimates), increasing both resilience to disturbance but also the severity of bistability. Focuses completely on autogeneic foundation species, since they allow their own initial positive feedbacks, and then compare the effects of mutualism that relieve the same stressor or unrelated ones. Relatively simple model allowing you to add and weight the two, and then performed some bifurcation analysis. Then devoted a lot o space to empirical examples, note that mutualisms can broaden niches sometimes even when not modifying the otherwise limiting stressor.}
}


