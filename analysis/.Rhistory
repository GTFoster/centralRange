#' @title Plot the graph (network) object
#'
#' @param g graph object
#' @param colz vector of colors (should be of length V(g))
#' @param nodeColor numeric vector to index color vector
#'   (should be of length V(g))
#' @param nodeSize numeric vector to scale node (vertex) size
#'   (should be of length V(g))
#'
#' @return a graph plot
plotGraph <- function(g,
nodeColor = membership(cluster_louvain(g)),
colz=viridis::viridis(length(unique(nodeColor))),
nodeSize = sqrt(degree(g)),
lay=layout_with_graphopt(g), ...){
#par(mar=c(0,0,0,0), oma=c(0,0,0,0))
plot(g, vertex.size=nodeSize*2, layout=lay,
vertex.color=colz[nodeColor], vertex.label=NA,
edge.arrow.size=0.5, edge.arrow.width=0.75,
edge.color='black', edge.curved=FALSE,
edge.width=E(g)$weight/max(E(g)$weight),
vertex.frame.color=colz[nodeColor], ...)
return(nodeColor)
}
plotGraph(g,
nodeColor=V(g)$type,
colz=c(1, 'dodgerblue'),
nodeSize=strength(g),
edge.width=E(g)$mnParVolumne/max(E(g)$mnParVolumne)
)
