path_parts <- c(path_parts, paste0("L ", coords[i,1], " ", coords[i,2]))
}
path_parts <- c(path_parts, "Z")  # Close path
return(paste(path_parts, collapse = " "))
}
# Simple path simplification (Douglas-Peucker-like)
simplify_path <- function(coords, tolerance) {
if(nrow(coords) <= 2) return(coords)
# Simple decimation for now - take every nth point
n <- max(1, floor(nrow(coords) / (nrow(coords) / tolerance)))
indices <- seq(1, nrow(coords), by = n)
if(tail(indices, 1) != nrow(coords)) {
indices <- c(indices, nrow(coords))  # Always include last point
}
return(coords[indices, ])
}
# Alternative approach using potrace-style vectorization
vectorize_logo_potrace_style <- function(input_path, output_path = "vectorized_logo_potrace.svg") {
# Read and preprocess image
img <- image_read(input_path) %>%
image_convert("grayscale") %>%
image_threshold("white", "50%")
# Save as temporary bitmap for processing
temp_bmp <- tempfile(fileext = ".bmp")
image_write(img, temp_bmp, format = "BMP")
# Process with magick's built-in vectorization
# This attempts to trace the bitmap
img_traced <- image_read(temp_bmp) %>%
image_convert("svg")
# Write the result
image_write(img_traced, output_path)
# Clean up
unlink(temp_bmp)
cat("Potrace-style vectorized logo saved to:", output_path, "\n")
return(output_path)
}
