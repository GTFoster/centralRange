}
}
# Function to vectorize a logo image
vectorize_logo <- function(input_path, output_path = "vectorized_logo.svg",
threshold = 0.5, simplify_tolerance = 2) {
# Read the image
img <- image_read(input_path)
# Convert to grayscale and ensure it's binary (black and white)
img_processed <- img %>%
image_convert("grayscale") %>%
image_threshold("white", paste0(threshold * 100, "%")) %>%
image_negate()  # Make sure black areas are the foreground
# Get image dimensions
info <- image_info(img_processed)
width <- info$width
height <- info$height
# Convert to matrix for processing
img_matrix <- as.numeric(image_data(img_processed, channels = "gray"))
img_matrix <- array(img_matrix, dim = c(width, height))
# Find contours using imager
img_imager <- as.cimg(img_matrix)
# Apply edge detection
edges <- imgradient(img_imager, "xy")
edge_magnitude <- sqrt(edges$x^2 + edges$y^2)
# Threshold edges
edge_binary <- edge_magnitude > quantile(edge_magnitude, 0.8)
# Find connected components
labeled <- label(edge_binary)
# Create SVG
svg_content <- create_svg_from_contours(labeled, width, height, simplify_tolerance)
# Write SVG file
writeLines(svg_content, output_path)
cat("Vectorized logo saved to:", output_path, "\n")
return(output_path)
}
# Function to create SVG from contours
create_svg_from_contours <- function(labeled_img, width, height, tolerance = 2) {
# SVG header
svg_header <- paste0(
'<?xml version="1.0" encoding="UTF-8"?>\n',
'<svg xmlns="http://www.w3.org/2000/svg" ',
'width="', width, '" height="', height, '" ',
'viewBox="0 0 ', width, ' ', height, '">\n'
)
# Convert labeled image to data frame for processing
coords <- which(labeled_img > 0, arr.ind = TRUE)
if(nrow(coords) == 0) {
return(paste0(svg_header, '</svg>'))
}
# Group coordinates by connected components
df <- data.frame(
x = coords[,1],
y = coords[,2],
label = labeled_img[coords]
)
# Create paths for each component
paths <- c()
for(label_val in unique(df$label)) {
if(label_val == 0) next
component_coords <- df[df$label == label_val, c("x", "y")]
if(nrow(component_coords) < 3) next
# Find hull or boundary
if(nrow(component_coords) > 3) {
hull_indices <- chull(component_coords$x, component_coords$y)
boundary_coords <- component_coords[hull_indices, ]
} else {
boundary_coords <- component_coords
}
# Simplify path if tolerance > 0
if(tolerance > 0) {
boundary_coords <- simplify_path(boundary_coords, tolerance)
}
# Create SVG path
if(nrow(boundary_coords) >= 3) {
path_d <- create_path_d(boundary_coords)
paths <- c(paths, paste0('<path d="', path_d, '" fill="black" stroke="none"/>'))
}
}
# SVG footer
svg_footer <- '</svg>'
# Combine all parts
svg_content <- paste0(
svg_header,
paste(paths, collapse = "\n"),
"\n",
svg_footer
)
return(svg_content)
}
# Function to create SVG path data
create_path_d <- function(coords) {
if(nrow(coords) < 2) return("")
path_parts <- c()
path_parts <- c(path_parts, paste0("M ", coords[1,1], " ", coords[1,2]))
for(i in 2:nrow(coords)) {
path_parts <- c(path_parts, paste0("L ", coords[i,1], " ", coords[i,2]))
}
path_parts <- c(path_parts, "Z")  # Close path
return(paste(path_parts, collapse = " "))
}
# Simple path simplification (Douglas-Peucker-like)
simplify_path <- function(coords, tolerance) {
if(nrow(coords) <= 2) return(coords)
# Simple decimation for now - take every nth point
n <- max(1, floor(nrow(coords) / (nrow(coords) / tolerance)))
indices <- seq(1, nrow(coords), by = n)
if(tail(indices, 1) != nrow(coords)) {
indices <- c(indices, nrow(coords))  # Always include last point
}
return(coords[indices, ])
}
